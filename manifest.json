{
    "manifest_version": 3,
    "name": "Gemini Form Filler",
    "short_name": "GFF",
    "version": "1.3.3.7",
    "description": "An extension that automatically fills Google Forms using Google Gemini",
    "homepage_url": "https://github.com/ArtikTheOnlyOne/gemini-form-filler",
    "permissions": [
        "activeTab",
        "storage",
        "scripting",
        "notifications"
    ],
    "host_permissions": [
        "https://docs.google.com/forms/*",
        "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background/service_worker.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": [
                "https://docs.google.com/forms/*"
            ],
            "js": [
                "content/content.js"
            ],
            "css": [
                "content/content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "states/*.svg"
            ],
            "matches": [
                "https://docs.google.com/*"
            ]
        },
        {
            "resources": [
                "content/content.css"
            ],
            "matches": [
                "https://docs.google.com/*"
            ]
        }
    ],
    "icons": {
        "16": "icons/gff16.png",
        "32": "icons/gff32.png",
        "48": "icons/gff48.png",
        "128": "icons/gff128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/gff16.png",
            "32": "icons/gff32.png",
            "48": "icons/gff48.png",
            "128": "icons/gff128.png"
        }
    }
}